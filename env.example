# Charm Generator Environment Configuration
# Copy this file to .env and fill in your values:
#   cp env.example .env

# =============================================================================
# OpenAI API Configuration
# =============================================================================

# Your OpenAI API key (required)
OPENAI_API_KEY=your-api-key-here

# Model to use for generation (optional, default: gpt-4o)
# Options: gpt-4o, gpt-4-turbo, gpt-4, gpt-3.5-turbo
OPENAI_MODEL=gpt-4o

# Maximum tokens for API response (optional, default: 16000)
OPENAI_MAX_TOKENS=16000

# Temperature for generation (optional, default: 0.3)
# Lower = more deterministic, Higher = more creative
OPENAI_TEMPERATURE=0.3

# API request timeout in seconds (optional, default: 120)
OPENAI_API_TIMEOUT=120

# Number of retry attempts for failed API calls (optional, default: 3)
OPENAI_API_RETRY_ATTEMPTS=3

# =============================================================================
# Logging Configuration
# =============================================================================

# Log level (optional, default: INFO)
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Enable metrics logging (optional, default: true)
ENABLE_METRICS=true

